{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "esbuild-watch",
            "type": "shell",
            "command": "node ./esbuild.js --watch",
            "isBackground": true,
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": "^✘ \\[ERROR\\] (.+)$",
                    "message": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^\\[esbuild\\]",
                    "endsPattern": "^⚡ Done"
                }
            }
        }
    ]
}
